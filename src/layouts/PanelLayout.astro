---
import { getSession } from "auth-astro/server";
import Sidebar from "../widgets/Sidebar/Sidebar.astro";
import Header from "../widgets/Header/Header.astro";
import "../styles/global.css"; // Ensure global styles (like glassmorphism variables) are loaded

interface Props {
  title?: string;
}

const { title = "Panel" } = Astro.props;

// Auth Check: Protect layout
const session = await getSession(Astro.request);

if (!session) {
  return Astro.redirect(`/api/auth/signin?callbackUrl=${Astro.url.pathname}`);
}
---

<html lang="es" class="scroll-smooth">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width" />
      <title>{title} | Janus Core</title>
      <meta name="theme-color" content="#0a0a0a" />
    </head>
    <body class="bg-bg text-text min-h-screen overflow-x-hidden">
      <!-- Mobile Sidebar Overlay -->
      <div id="mobile-overlay" class="fixed inset-0 bg-bg/80 backdrop-blur-sm z-40 hidden md:hidden transition-opacity opacity-0"></div>

      <Sidebar user={session?.user} currentPath={Astro.url.pathname} />

      <!-- Main Content Wrapper -->
      <div id="main-content-wrapper" class="flex flex-col min-h-screen transition-all duration-300 md:pl-64 data-[collapsed=true]:md:pl-20">
        <Header user={session?.user} title={title} />
        
        <main class="flex-1 p-6 lg:p-8 w-full max-w-7xl mx-auto">
          <slot />
        </main>
      </div>

      <script>
        // Sync layout margin with sidebar state
        const setupLayoutSync = () => {
          const sidebar = document.getElementById('app-sidebar');
          const wrapper = document.getElementById('main-content-wrapper');
          const toggleBtn = document.getElementById('sidebar-toggle');
          
          const mobileOverlay = document.getElementById('mobile-overlay');
          const mobileToggle = document.getElementById('mobile-sidebar-toggle');

          if (!sidebar || !wrapper) return;

          // Mobile logic
          let mobileOpen = false;
          
          // Hide sidebar on mobile by default using a class
          sidebar.classList.add('-translate-x-full', 'md:translate-x-0');

          if (mobileToggle && mobileOverlay) {
            mobileToggle.onclick = () => {
              mobileOpen = true;
              sidebar.classList.remove('-translate-x-full');
              mobileOverlay.classList.remove('hidden');
              setTimeout(() => mobileOverlay.classList.remove('opacity-0'), 10);
            };

            mobileOverlay.onclick = () => {
              mobileOpen = false;
              sidebar.classList.add('-translate-x-full');
              mobileOverlay.classList.add('opacity-0');
              setTimeout(() => mobileOverlay.classList.add('hidden'), 300);
            };
          }

          // Desktop Sync Logic
          const syncWrapper = () => {
            const isCollapsed = sidebar.getAttribute('data-collapsed') === 'true';
            wrapper.setAttribute('data-collapsed', isCollapsed.toString());
          };

          // Initial sync
          syncWrapper();

          // Listen to toggle clicks
          if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
              setTimeout(syncWrapper, 10);
            });
          }
        };

        setupLayoutSync();
        document.addEventListener('astro:page-load', setupLayoutSync);
      </script>
    </body>
  </html>
