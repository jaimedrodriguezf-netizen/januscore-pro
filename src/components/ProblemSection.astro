---
import ScrollReveal from './react/ScrollReveal';
---

<section id="problema" class="py-24 md:py-32 relative overflow-hidden">
  {/* Background accents */}
  <div class="absolute top-1/4 -left-64 w-96 h-96 bg-primary/10 blur-[120px] rounded-full"></div>
  <div class="absolute bottom-1/4 -right-64 w-96 h-96 bg-secondary/10 blur-[120px] rounded-full"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 md:gap-24 items-center">
        
        {/* Physical world */}
        <ScrollReveal client:visible direction="right">
          <div class="text-right space-y-6">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/5 border border-white/10 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-text">
              El mundo físico
            </h2>
            <p class="text-lg md:text-xl text-text-secondary leading-relaxed font-light">
              Tus máquinas, sensores y activos generan datos todo el tiempo. 
              Temperatura, vibración, movimientos, accesos — señales que cuentan 
              la historia de tu operación. Pero si nadie las escucha, son solo ruido.
            </p>
          </div>
        </ScrollReveal>

        {/* Visual Gap / Connector */}
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 hidden md:flex flex-col items-center py-8">
          <div class="w-px h-32 bg-gradient-to-b from-primary via-secondary to-accent shadow-[0_0_15px_rgba(0,212,255,0.5)]"></div>
          <div class="my-6 w-14 h-14 rounded-full border-2 border-white/10 flex items-center justify-center bg-bg relative">
             <div class="absolute inset-0 rounded-full bg-primary/20 animate-ping"></div>
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6 text-primary relative z-10">
                <path d="M12 5v14M5 12h14" stroke-linecap="round" />
             </svg>
          </div>
          <div class="w-px h-32 bg-gradient-to-b from-accent via-secondary to-primary shadow-[0_0_15px_rgba(0,255,136,0.5)]"></div>
        </div>

        {/* Digital world */}
        <ScrollReveal client:visible direction="left">
          <div class="space-y-6">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary/10 border border-primary/20 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-text">
              La inteligencia digital
            </h2>
            <p class="text-lg md:text-xl text-text-secondary leading-relaxed font-light">
              Modelos de IA, dashboards y automatizaciones que podrían transformar 
              tu operación. Pero sin datos del mundo real, son inteligencia sin 
              contexto — teorías que no resuelven problemas concretos.
            </p>
          </div>
        </ScrollReveal>
      </div>

      <ScrollReveal client:visible delay={0.4}>
        <div class="text-center mt-24 md:mt-32">
          <p class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">
            El problema no es la tecnología. Es la brecha entre ambos mundos.
          </p>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
