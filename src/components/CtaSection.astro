---
import ScrollReveal from './react/ScrollReveal';
import { siteData } from '../data/siteData';

const whatsappUrl = `https://wa.me/${siteData.contactPhone.replace(/[^0-9]/g, '')}?text=${encodeURIComponent('Hola Janus Core, me interesa un proyecto.')}`;
---

<section id="contacto" class="py-20 md:py-32 bg-gradient-to-b from-bg to-surface/30 overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
        
        <ScrollReveal client:visible direction="right" className="w-full max-w-full">
          <div class="space-y-6 sm:space-y-8 w-full max-w-full">
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-text leading-tight">
              ¿Listo para cerrar <span class="text-primary">la brecha?</span>
            </h2>
            <p class="text-lg sm:text-xl text-text-secondary leading-relaxed font-light">
              Contanos sobre tu proyecto. Te mostramos cómo conectar tus activos físicos 
              con la inteligencia que los hace brillar — sin vueltas.
            </p>
            
            <div class="space-y-4 sm:space-y-6 w-full max-w-full">
              {[
                'Respuesta profesional y personalizada',
                'Consultoría enfocada en resultados técnicos',
                'Diseño de soluciones a medida para tu industria'
              ].map(item => (
                <div class="flex items-start gap-3 sm:gap-4 group w-full max-w-full">
                  <div class="w-5 h-5 sm:w-6 sm:h-6 shrink-0 rounded-full bg-primary/20 flex items-center justify-center mt-1 group-hover:bg-primary transition-colors duration-300">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-3 h-3 sm:w-3.5 sm:h-3.5 text-primary group-hover:text-bg transition-colors duration-300">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                  </div>
                  <span class="text-sm sm:text-base text-text-secondary group-hover:text-text transition-colors duration-300 leading-snug flex-1">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </ScrollReveal>

        <ScrollReveal client:visible direction="left" className="w-full max-w-full">
          <div class="bg-surface border border-white/5 rounded-3xl p-5 sm:p-8 md:p-10 shadow-2xl shadow-primary/5 space-y-6 sm:space-y-8 overflow-hidden w-full max-w-full">
            <h3 class="text-xl sm:text-2xl font-bold text-text">Datos de contacto</h3>
            
            <div class="space-y-4 sm:space-y-6 w-full max-w-full">
              <a 
                href={`mailto:${siteData.contactEmail}`}
                class="flex items-center gap-4 p-4 sm:p-6 rounded-2xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all group overflow-hidden w-full max-w-full"
              >
                <div class="w-10 h-10 sm:w-12 sm:h-12 shrink-0 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-bg transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sm:w-6 sm:h-6"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-[10px] sm:text-xs text-text-secondary uppercase tracking-widest mb-0.5 sm:mb-1">E-mail</p>
                  <p class="text-sm sm:text-lg font-medium text-text truncate break-all">{siteData.contactEmail}</p>
                </div>
              </a>

              <a 
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 sm:p-6 rounded-2xl bg-white/5 border border-white/10 hover:border-[#25D366]/50 transition-all group overflow-hidden w-full max-w-full"
              >
                <div class="w-10 h-10 sm:w-12 sm:h-12 shrink-0 rounded-xl bg-[#25D366]/10 flex items-center justify-center text-[#25D366] group-hover:bg-[#25D366] group-hover:text-bg transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sm:w-6 sm:h-6"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-[10px] sm:text-xs text-text-secondary uppercase tracking-widest mb-0.5 sm:mb-1">WhatsApp</p>
                  <p class="text-sm sm:text-lg font-medium text-text truncate">{siteData.contactPhone}</p>
                </div>
              </a>
            </div>

            <div class="pt-4 border-t border-white/5">
              <p class="text-xs sm:text-sm text-text-secondary font-light italic leading-relaxed">
                Estamos en Quito, Ecuador, disponibles para proyectos globales.
              </p>
            </div>
          </div>
        </ScrollReveal>

      </div>
    </div>
  </div>
</section>
