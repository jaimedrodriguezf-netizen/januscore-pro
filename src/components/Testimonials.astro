---
import TestimonialCarousel from './react/TestimonialCarousel';
import { useCases } from '../data/useCases';
import ScrollReveal from './react/ScrollReveal';
---

<section id="casos" class="py-24 md:py-32 border-b border-white/5 overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal client:visible>
        <div class="text-center mb-20">
          <h2 class="text-4xl md:text-5xl font-bold text-text mb-6">
            Casos de uso
          </h2>
          <p class="text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed font-light">
            De la teoría a la práctica. Esto es lo que ya estamos construyendo y operando hoy mismo.
          </p>
        </div>
      </ScrollReveal>

      <TestimonialCarousel client:visible cases={useCases} />
    </div>
  </div>
</section>
