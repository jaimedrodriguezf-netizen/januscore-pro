---
import { businessUnits } from '../../data/businessUnits';
---

<section
  id="servicios"
  class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-surface/50"
>
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 md:mb-20">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-text mb-6">
        Soluciones que conectan <span class="text-primary">ambos mundos</span>
      </h2>
      <p class="text-lg text-text-secondary max-w-3xl mx-auto leading-relaxed">
        Tres unidades de negocio que trabajan en conjunto para llevar
        inteligencia a tus operaciones físicas y datos concretos a tus
        decisiones digitales.
      </p>
    </div>

    <!-- Business unit cards grid — placeholder for React BusinessUnitCard islands -->
    <div class="grid md:grid-cols-3 gap-6 md:gap-8">
      {
        businessUnits.map((unit) => (
          <div
            id={`bu-card-${unit.id}`}
            class="relative bg-bg rounded-2xl p-8 border border-white/5 overflow-hidden group"
          >
            {/* Color accent strip */}
            <div
              class="absolute top-0 left-0 right-0 h-1 opacity-60 group-hover:opacity-100 transition-opacity"
              style={{
                backgroundColor: `var(--color-${unit.color})`,
              }}
            />

            {/* Icon placeholder — React island will enhance */}
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center mb-6"
              style={{
                backgroundColor: `color-mix(in srgb, var(--color-${unit.color}) 15%, transparent)`,
                color: `var(--color-${unit.color})`,
              }}
            >
              {unit.icon === 'cpu' && (
                <svg
                  class="w-6 h-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8.25 3v1.5M16.5 3v1.5M3 8.25h1.5M3 16.5h1.5M3 12h18m-3-3.75V19.5m-12 0V8.25m15 0H3m15 0v1.5m0-1.5h-1.5m-12 0H4.5m1.5 0V19.5m12 0h1.5m-1.5 0v-1.5m-12 1.5v-1.5M12 3v1.5M12 19.5V21m-3-9h.008v.008H9V12Zm3 0h.008v.008H12V12Zm3 0h.008v.008H15V12Z"
                  />
                </svg>
              )}
              {unit.icon === 'eye' && (
                <svg
                  class="w-6 h-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                  />
                </svg>
              )}
              {unit.icon === 'monitor' && (
                <svg
                  class="w-6 h-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.75 6A2.25 2.25 0 0 1 6 3.75h12A2.25 2.25 0 0 1 20.25 6v7.5A2.25 2.25 0 0 1 18 15.75H6A2.25 2.25 0 0 1 3.75 13.5V6Zm-1.5 9.75h19.5m-19.5 0a2.25 2.25 0 0 0-2.25 2.25v.75a2.25 2.25 0 0 0 2.25 2.25h19.5a2.25 2.25 0 0 0 2.25-2.25v-.75a2.25 2.25 0 0 0-2.25-2.25H2.25Z"
                  />
                </svg>
              )}
            </div>

            {/* Content */}
            <h3 class="text-xl font-bold text-text mb-3">{unit.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-6">
              {unit.description}
            </p>

            {/* Tech tags */}
            <div class="flex flex-wrap gap-2">
              {unit.tags.map((tag) => (
                <span
                  class="inline-flex px-3 py-1 text-xs font-mono rounded-full border"
                  style={{
                    borderColor: `color-mix(in srgb, var(--color-${unit.color}) 30%, transparent)`,
                    color: `var(--color-${unit.color})`,
                  }}
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
