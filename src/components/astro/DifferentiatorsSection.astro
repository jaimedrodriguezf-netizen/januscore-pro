---
import { differentiators } from '../../data/differentiators';
---

<section
  id="diferenciadores"
  class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 relative"
>
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 md:mb-20">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-text mb-6">
        Lo que nos hace <span class="text-primary">diferentes</span>
      </h2>
      <p class="text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">
        No hacemos lo mismo que todos. Nuestra arquitectura tecnológica está
        pensada para darte soberanía, seguridad y flexibilidad real.
      </p>
    </div>

    <!-- Differentiators list -->
    <div class="grid md:grid-cols-3 gap-8">
      {
        differentiators.map((item, index) => {
          // Cycle through brand colors for accent borders
          const colors = [
            'var(--color-primary)',
            'var(--color-secondary)',
            'var(--color-accent)',
          ];
          const accentColor = colors[index % colors.length];
          const isHighlighted = item.highlight;

          return (
            <div
              class={`relative rounded-2xl p-8 border transition-all duration-300 ${
                isHighlighted
                  ? 'bg-primary/5 border-primary/20'
                  : 'bg-surface border-white/5 hover:border-white/10'
              }`}
            >
              {/* Accent border */}
              <div
                class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl"
                style={{ backgroundColor: accentColor }}
              />

              {/* Highlight badge */}
              {isHighlighted && (
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold mb-6 bg-primary/10 text-primary border border-primary/20">
                  <svg
                    class="w-3 h-3"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"
                    />
                  </svg>
                  Privacidad real
                </span>
              )}

              {/* Icon */}
              <div
                class={`w-12 h-12 rounded-xl flex items-center justify-center mb-6 ${
                  isHighlighted ? '' : ''
                }`}
                style={{
                  backgroundColor: isHighlighted
                    ? 'color-mix(in srgb, var(--color-primary) 15%, transparent)'
                    : 'color-mix(in srgb, var(--color-surface) 80%, white)',
                  color: accentColor,
                }}
              >
                {item.icon === 'shield' && (
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
                    />
                  </svg>
                )}
                {item.icon === 'network' && (
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"
                    />
                  </svg>
                )}
                {item.icon === 'code' && (
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"
                    />
                  </svg>
                )}
              </div>

              {/* Title */}
              <h3 class="text-xl font-bold text-text mb-3">{item.title}</h3>

              {/* Description */}
              <p class="text-text-secondary text-sm leading-relaxed">
                {item.description}
              </p>

              {/* Tech detail label for highlighted item */}
              {isHighlighted && (
                <div class="mt-6 pt-6 border-t border-primary/10">
                  <span class="text-xs font-mono text-primary/60">
                    ollama run llama3 --local --private
                  </span>
                </div>
              )}
            </div>
          );
        })
      }
    </div>

    <!-- Bottom accent bar -->
    <div class="mt-16 text-center">
      <div class="inline-flex gap-3">
        <span class="w-3 h-3 rounded-full bg-primary"></span>
        <span class="w-3 h-3 rounded-full bg-secondary"></span>
        <span class="w-3 h-3 rounded-full bg-accent"></span>
      </div>
    </div>
  </div>
</section>
