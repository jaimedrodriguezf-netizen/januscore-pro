---
import { siteData } from '../../data/siteData';
import { businessUnits } from '../../data/businessUnits';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title = 'Janus Core | Bits, Átomos e Inteligencia',
  description = siteData.description,
  ogImage = siteData.ogImage,
  canonicalUrl = siteData.url,
} = Astro.props;

const ogUrl = canonicalUrl;
const ogUrlFull = ogImage.startsWith('http')
  ? ogImage
  : `${siteData.url}${ogImage}`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="generator" content={Astro.generator} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogUrlFull} />
<meta property="og:url" content={ogUrl} />
<meta property="og:site_name" content={siteData.name} />
<meta property="og:locale" content="es_EC" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogUrlFull} />

<!-- JSON-LD: Organization -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: siteData.name,
    url: siteData.url,
    logo: `${siteData.url}/favicon.svg`,
    description: siteData.description,
    sameAs: siteData.socialLinks.map((l) => l.href),
    contactPoint: {
      '@type': 'ContactPoint',
      email: siteData.contactEmail,
      contactType: 'customer service',
      areaServed: 'EC',
      availableLanguage: 'Spanish',
    },
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Quito',
      addressCountry: 'EC',
    },
  })}
/>

<!-- JSON-LD: Product schemas per business unit -->
<script
  type="application/ld+json"
  set:html={JSON.stringify(
    businessUnits.map((unit) => ({
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: unit.title,
      description: unit.description,
      category: unit.shortTitle,
      offers: {
        '@type': 'Offer',
        availability: 'https://schema.org/InStock',
      },
    })),
  )}
/>
