---
// Pain points data for the physical-digital gap narrative
const painPoints = [
  {
    icon: 'factory',
    title: 'Activos físicos que no hablan',
    description:
      'Tus máquinas, sensores y dispositivos generan datos que nadie escucha. Sin conexión ni inteligencia, la información se pierde y las decisiones se toman a ciegas.',
    color: 'var(--color-primary)',
  },
  {
    icon: 'bridge',
    title: 'Datos sin contexto ni acción',
    description:
      'Acumulás terabytes de datos en silos aislados. No hay análisis en tiempo real, no hay alertas predictivas — solo dashboards bonitos que no resuelven problemas.',
    color: 'var(--color-secondary)',
  },
  {
    icon: 'cloud-off',
    title: 'Dependencia externa que frena',
    description:
      'Soluciones en la nube que no llegan, APIs que fallan, datos que viajan afuera de tu red. Dependés de terceros para lo que debería ser tuyo.',
    color: 'var(--color-accent)',
  },
];
---

<section id="problema" class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 relative">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 md:mb-20">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-text mb-6">
        El mundo físico y el digital <span class="text-primary"
          >no se entienden</span
        >
      </h2>
      <p class="text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">
        Hoy tus operaciones y tu tecnología están desconectadas. Y esa
        desconexión tiene un costo real.
      </p>
    </div>

    <!-- Pain points grid -->
    <div class="grid md:grid-cols-3 gap-6 md:gap-8 mb-16">
      {
        painPoints.map((point, i) => (
          <div
            class="group relative bg-surface rounded-2xl p-8 border border-white/5 hover:border-white/10 transition-all duration-300 hover:-translate-y-1"
          >
            {/* Accent line */}
            <div
              class="absolute top-0 left-8 right-8 h-0.5 rounded-full opacity-60 group-hover:opacity-100 transition-opacity"
              style="background-color: {point.color}"
            />

            {/* Icon */}
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center mb-6"
              style="background-color: color-mix(in srgb, {point.color} 15%, transparent); color: {point.color}"
            >
              {point.icon === 'factory' && (
                <svg
                  class="w-6 h-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Z"
                  />
                </svg>
              )}
              {point.icon === 'bridge' && (
                <svg
                  class="w-6 h-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"
                  />
                </svg>
              )}
              {point.icon === 'cloud-off' && (
                <svg
                  class="w-6 h-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12"
                  />
                </svg>
              )}
            </div>

            {/* Title */}
            <h3 class="text-xl font-bold text-text mb-3">{point.title}</h3>

            {/* Description */}
            <p class="text-text-secondary text-sm leading-relaxed">
              {point.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Transition CTA -->
    <div class="text-center">
      <p class="text-text-secondary mb-6 text-base">
        La brecha entre lo físico y lo digital no tiene por qué existir.
      </p>
      <a
        href="#servicios"
        class="inline-flex items-center gap-2 text-primary font-semibold hover:text-primary/80 transition-colors group"
      >
        Conocé cómo lo solucionamos
        <svg
          class="w-5 h-5 transition-transform group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
