---
import { siteData } from '../../data/siteData';
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Dark gradient overlay background -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-bg via-bg/95 to-surface pointer-events-none z-0"
  >
  </div>

  <!-- Canvas animation placeholder — React HeroAnimation island (client:load) -->
  <div id="hero-canvas" class="absolute inset-0 z-0" aria-hidden="true"></div>

  <!-- Content -->
  <div
    class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-32 md:py-40"
  >
    <!-- Tagline / eyebrow -->
    <p
      class="inline-block text-sm font-mono text-primary/80 tracking-widest uppercase mb-6 border border-primary/20 rounded-full px-4 py-1.5 bg-primary/5"
    >
      {siteData.name} — {siteData.tagline}
    </p>

    <!-- Headline -->
    <h1
      class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6 text-text"
    >
      {siteData.tagline}
    </h1>

    <!-- Subheadline -->
    <p class="text-xl sm:text-2xl md:text-3xl font-medium text-primary mb-8">
      Conectamos tus activos con el futuro
    </p>

    <!-- Description -->
    <p
      class="text-base sm:text-lg text-text-secondary max-w-2xl mx-auto mb-12 leading-relaxed"
    >
      {siteData.description}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <!-- Primary CTA -->
      <a
        href="#servicios"
        class="inline-flex items-center px-8 py-4 rounded-full bg-primary text-bg font-bold text-base hover:bg-primary/90 transition-all duration-200 shadow-xl shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-0.5"
      >
        Descubrí cómo
        <svg
          class="ml-2 w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>

      <!-- Secondary CTA -->
      <a
        href="#casos"
        class="inline-flex items-center px-8 py-4 rounded-full border border-text-secondary/30 text-text-secondary font-semibold text-base hover:border-text-secondary/60 hover:text-text transition-all duration-200"
      >
        Ver casos de uso
        <svg
          class="ml-2 w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div
    class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-surface to-transparent pointer-events-none z-10"
  >
  </div>
</section>
