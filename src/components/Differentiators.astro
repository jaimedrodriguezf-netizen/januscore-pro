---
import ScrollReveal from './react/ScrollReveal';
import { differentiators } from '../data/differentiators';
---

<section id="diferenciadores" class="py-24 md:py-32 relative overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal client:visible>
        <div class="text-center mb-20">
          <h2 class="text-4xl md:text-5xl font-bold text-text mb-6">
            Nosotros hacemos distinto
          </h2>
          <p class="text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed font-light">
            No seguimos modas. Construimos soluciones que respetan tu infraestructura, tus datos y tu presupuesto.
          </p>
        </div>
      </ScrollReveal>

      <div class="grid md:grid-cols-3 gap-8">
        {differentiators.map((diff, index) => (
          <ScrollReveal client:visible delay={index * 0.1}>
            <div
              class={`h-full bg-surface rounded-3xl p-8 border transition-all duration-500 hover:-translate-y-2 relative group overflow-hidden ${
                diff.highlight ? 'border-primary/40 shadow-[0_0_30px_rgba(0,212,255,0.1)]' : 'border-white/5 hover:border-primary/20'
              }`}
            >
              {diff.highlight && (
                <div class="absolute -top-1 -right-1">
                  <div class="bg-primary text-bg text-[10px] font-black uppercase tracking-widest px-4 py-1.5 rounded-bl-2xl">
                    Prioridad: Privacidad
                  </div>
                </div>
              )}
              
              <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7 text-primary">
                  {diff.icon === 'shield' && (
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round" />
                  )}
                  {diff.icon === 'network' && (
                    <>
                      <circle cx="12" cy="4" r="2" />
                      <circle cx="4" cy="20" r="2" />
                      <circle cx="20" cy="20" r="2" />
                      <path d="M12 6v6M4 18l4-6M20 18l-4-6" stroke-linecap="round" stroke-linejoin="round" />
                    </>
                  )}
                  {diff.icon === 'code' && (
                    <>
                      <polyline points="16 18 22 12 16 6" stroke-linecap="round" stroke-linejoin="round" />
                      <polyline points="8 6 2 12 8 18" stroke-linecap="round" stroke-linejoin="round" />
                    </>
                  )}
                </svg>
              </div>
              
              <h3 class="text-2xl font-bold text-text mb-4 group-hover:text-primary transition-colors">{diff.title}</h3>
              <p class="text-text-secondary leading-relaxed font-light">{diff.description}</p>
              
              {/* Decorative line at the bottom */}
              <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/20 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-700"></div>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </div>
</section>
