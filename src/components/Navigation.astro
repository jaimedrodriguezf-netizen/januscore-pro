---
import { siteData } from '../data/siteData';
import MobileNav from './react/MobileNav';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
---

<header
  id="main-nav"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-300 h-20 flex items-center"
>
  <div class="container mx-auto px-6 flex items-center justify-between">
    <a
      href="#inicio"
      class="text-2xl font-bold tracking-tighter flex items-center gap-2 group"
    >
      <img 
        src="/favicon.svg" 
        alt="Janus Core Logo" 
        class="w-10 h-10 rounded-xl shadow-lg shadow-primary/20 transform transition-transform duration-300 group-hover:rotate-12 group-hover:scale-110" 
      />
      <span
        class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent font-sans"
      >
        {siteData.name}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-6 lg:gap-10">
      {
        siteData.navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-text-secondary hover:text-primary transition-colors duration-200 relative group py-2"
          >
            {link.label}
            <span class="absolute bottom-1 left-0 w-0 h-0.5 bg-primary transition-all duration-300 group-hover:w-full" />
          </a>
        ))
      }
      <div class="flex items-center gap-4 border-l border-white/10 pl-6 ml-2">
        {session ? (
          <a
            href="/panel"
            class="text-sm font-medium text-text-secondary hover:text-primary transition-colors duration-200"
          >
            Panel
          </a>
        ) : (
          <a
            href="/api/auth/signin?callbackUrl=/panel"
            class="text-sm font-medium text-text-secondary hover:text-primary transition-colors duration-200"
          >
            Iniciar Sesión
          </a>
        )}
        <a
          href="#contacto"
          class="px-6 py-2.5 bg-gradient-to-r from-primary/10 to-secondary/10 border border-primary/20 text-primary rounded-full text-sm font-bold hover:from-primary hover:to-secondary hover:text-bg transition-all duration-500 shadow-lg shadow-primary/5 hover:shadow-primary/20"
        >
          Hablemos
        </a>
      </div>
    </nav>

    {
      /* Mobile Navigation (React island) - Absolute positioning for precise alignment and no-displacement */
    }
    <div class="md:hidden absolute right-6 inset-y-0 flex items-center">
      <MobileNav
        client:load
        links={siteData.navLinks}
        email={siteData.contactEmail}
        phone={siteData.contactPhone}
        socialLinks={siteData.socialLinks}
        isLoggedIn={!!session}
      />
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('main-nav');

  const handleScroll = () => {
    if (window.scrollY > 80) {
      header?.classList.add(
        'bg-bg/80',
        'backdrop-blur-xl',
        'border-b',
        'border-white/5',
        'h-16',
      );
      header?.classList.remove('h-20');
    } else {
      header?.classList.remove(
        'bg-bg/80',
        'backdrop-blur-xl',
        'border-b',
        'border-white/5',
        'h-16',
      );
      header?.classList.add('h-20');
    }
  };

  window.addEventListener('scroll', handleScroll, { passive: true });
  // Initial check in case of refresh
  handleScroll();
</script>
