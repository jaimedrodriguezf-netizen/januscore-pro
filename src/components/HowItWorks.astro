---
import ProcessTimeline from './react/ProcessTimeline';
import { processSteps } from '../data/processSteps';
import ScrollReveal from './react/ScrollReveal';
---

<section id="como-funciona" class="py-24 md:py-32 border-b border-white/5 relative">
  <div class="container mx-auto px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal client:visible>
        <div class="text-center mb-20">
          <h2 class="text-4xl md:text-5xl font-bold text-text mb-6">
            Cómo funciona
          </h2>
          <p class="text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed font-light">
            Tres pasos. Sin vueltas. Del mundo físico a la decisión inteligente en un flujo continuo y seguro.
          </p>
        </div>
      </ScrollReveal>

      <ProcessTimeline client:visible steps={processSteps} />
    </div>
  </div>
</section>
